class Dims(TypedDict, total=False):
    # Width in pixels
    width: Required[int]
    # Height in pixels
    height: Required[int]

class Image(TypedDict, total=False):
    # Width in pixels
    width: Required[int]
    # Height in pixels
    height: Required[int]
    path: Required[str]
